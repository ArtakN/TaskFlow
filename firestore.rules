rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnDocument() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnership() {
      return request.resource.data.userId == resource.data.userId;
    }

    match /boards/{boardId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsResource();
      allow update: if ownsResource() && keepsOwnership();
    }

    match /lists/{listId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsResource();
      allow update: if ownsResource() && keepsOwnership();
    }

    match /tasks/{taskId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsResource();
      allow update: if ownsResource() && keepsOwnership();
    }
  }
}
